# ══════════════════════════════════════════════════════════════
# CaliStrength Backend — Production Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env on your production server.

# ── MySQL Database ──────────────────────────────────────────
DB_HOST=your-mysql-host.com
DB_PORT=3306
DB_USER=calistrength_user
DB_PASSWORD=strong_random_password_here
DB_NAME=calistrength

# ── App Settings ─────────────────────────────────────────────
# Generate a new secret: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=generate_a_new_64_char_hex_secret
ENVIRONMENT=production

# ── CORS (your deployed React frontend URL) ─────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Firebase ─────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
